<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/filmr_bg_darkest">

    <com.reilandeubank.unprocess.utils.AutoFitSurfaceView
        android:id="@+id/view_finder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:foreground="@android:color/transparent" />

    <com.reilandeubank.unprocess.utils.HistogramView
        android:id="@+id/histogram_view"
        android:layout_width="96dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:layout_marginTop="64dp" />

    <TextView
        android:id="@+id/filmr_unavailable_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC8B0000"
        android:gravity="center"
        android:padding="8dp"
        android:text="@string/filmr_engine_unavailable"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Tap-to-focus ring: positioned programmatically at the touch point -->
    <ImageView
        android:id="@+id/focus_ring"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_focus_ring"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Settings button — top-right -->
    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_settings"
        android:background="@drawable/bg_filmr_camera_button"
        android:contentDescription="@string/settings" />

    <!-- Film info + capture button — right side in landscape -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center|end"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/filmr_overlay_bar"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/capture_button"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="fitCenter"
            android:background="@drawable/ic_shutter"
            android:contentDescription="@string/capture" />

        <TextView
            android:id="@+id/film_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/film_info_default"
            android:textColor="@color/filmr_text_secondary"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Film preset quick-select strip -->
        <HorizontalScrollView
            android:id="@+id/preset_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp">
            <LinearLayout
                android:id="@+id/preset_chip_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:divider="@android:drawable/divider_horizontal_bright"
                android:showDividers="none" />
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Processing overlay: shown while capture + filmr simulation are running -->
    <FrameLayout
        android:id="@+id/capture_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:gravity="center">
        <ProgressBar
            android:id="@+id/capture_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true" />
        <TextView
            android:id="@+id/capture_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="80dp"
            android:text="@string/capture_status_processing"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </FrameLayout>

</FrameLayout>
